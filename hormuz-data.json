plomatic"}, {"time": "04-22 11:20", "title": "🧊 万斯赴巴行程被搁置｜美方谈判计划受挫", "desc": "NYT/CNBC等多家美媒援引官员消息，副总统万斯原定赴巴基斯坦主持第二轮美伊谈判的行程已被搁置，因伊朗方面迟迟未确认派出代表团。伊朗坚持美国必须先解除海峡封锁。（NYT/CNBC）", "type": "diplomatic"}, {"time": "04-22 09:20", "title": "🗣️ 叙事对撞｜伊朗否认求延长｜UN大使：解封才谈", "desc": "塔斯尼姆通讯社援引消息称，伊朗方面并未要求延长与美停火期限，反指特朗普违约。伊朗常驻UN大使表态：美国解除海峡封锁之前，伊方不派代表团谈判。（塔斯尼姆/NBC）", "type": "diplomatic"}, {"time": "04-22 08:20", "title": "🚢 美军扣图斯卡号｜海峡重开但无船敢走", "desc": "CENTCOM证实，史普鲁恩斯号驱逐舰拦截图斯卡号（自中国开往伊朗），指其违反美国封锁。海峡虽重开，但航运实际瘫痪，船只普遍绕行。（CBS/DW/CENTCOM）", "type": "military"}], "insightText": "封锁第5天关键节点：IRGC连续扣押货轮，UKMTO警告区域活动水平极高，美防部评估排雷需6个月。停火虽延长，海峡实况持续恶化。", "insightTime": "4/23 06:00 · 整点更新", "shipCountNews": 3, "shipChgNews": "0", "lngStatus": "⚠️ 事实封锁", "lngNote": "封锁第5天｜IRGC扣押MSC Francesca+Epaminondas｜UKMTO警告活动水平极高｜排雷恐需6个月", "oilWtiChgRaw": -0.43, "goldChgRaw": 1.21, "goldIsRealtime": false, "oilIsRealtime": false, "isWeekend": false, "wtiPrice": 89.28, "wtiChange": "-0.43%", "goldChange": "+1.21%", "goldDir": "up", "wti": 89.28, "wtiChg": -1.25, "gold": 4776.6, "lastUpdated": "2026-04-23T00:18:58+08:00"}